# ---- Server ----
PORT=8080
NODE_ENV=production
# Comma-separated list of allowed origins for CORS + Socket.IO (your Flutter web build,
# or "*" while developing — do NOT use "*" in production).
CORS_ORIGINS=*

# ---- Turso Database (replaces Supabase) ----
# Get these from: https://turso.tech/
# 1. Create account at turso.tech
# 2. Run: turso db create chess-online
# 3. Run: turso db show chess-online --url
# 4. Run: turso db tokens create chess-online
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=

# ---- JWT Authentication (replaces Supabase Auth) ----
# Generate secure random strings (at least 32 characters each):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ---- Matchmaking ----
MATCHMAKING_TIMEOUT_MS=60000
# Max Elo gap the queue will accept immediately; widens over time while waiting.
MATCHMAKING_INITIAL_ELO_RANGE=100
MATCHMAKING_MAX_ELO_RANGE=600
# When a player hits MATCHMAKING_TIMEOUT_MS with no human opponent, pair
# them with a bot account instead of leaving them waiting. Set to the
# literal text "false" to disable (any other value, including unset, means
# enabled).
MATCHMAKING_BOT_FALLBACK_ENABLED=true

# ---- OAuth login (optional) ----
# Leave blank to ship with Google/Facebook sign-in disabled - /api/auth/oauth/*
# then returns a clean 401 instead of working, everything else (guest,
# email) is unaffected. See game/docs/OAUTH_SETUP.md in the Flutter repo
# for how to obtain these.
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ---- Game defaults ----
DEFAULT_TIME_CONTROL_MINUTES=10
DEFAULT_TIME_CONTROL_INCREMENT_SEC=5
RECONNECT_GRACE_MS=30000

# ---- Rate limiting ----
HTTP_RATE_LIMIT_WINDOW_MS=60000
HTTP_RATE_LIMIT_MAX=120
SOCKET_MOVE_RATE_LIMIT_PER_SEC=10
