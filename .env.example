# ---- Server ----
PORT=8080
NODE_ENV=production
# Comma-separated list of allowed origins for CORS + Socket.IO (your Flutter web build,
# or "*" while developing — do NOT use "*" in production).
CORS_ORIGINS=*

# ---- Supabase ----
# Project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=
# anon/public key — only used to validate that a JWT was issued by this project.
SUPABASE_ANON_KEY=
# service_role key — NEVER expose this to the client. Server-only. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Matchmaking ----
MATCHMAKING_TIMEOUT_MS=60000
# Max Elo gap the queue will accept immediately; widens over time while waiting.
MATCHMAKING_INITIAL_ELO_RANGE=100
MATCHMAKING_MAX_ELO_RANGE=600

# ---- Game defaults ----
DEFAULT_TIME_CONTROL_MINUTES=10
DEFAULT_TIME_CONTROL_INCREMENT_SEC=5
RECONNECT_GRACE_MS=30000

# ---- Rate limiting ----
HTTP_RATE_LIMIT_WINDOW_MS=60000
HTTP_RATE_LIMIT_MAX=120
SOCKET_MOVE_RATE_LIMIT_PER_SEC=10
